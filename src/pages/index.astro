---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Problem from '../components/Problem.astro';
import Solution from '../components/Solution.astro';
import Demo from '../components/Demo.astro';
import AhaMoment from '../components/AhaMoment.astro';
import Features from '../components/Features.astro';
import Audiences from '../components/Audiences.astro';
import TEDTalk from '../components/TEDTalk.astro';
import Evidence from '../components/Evidence.astro';
import Testimonials from '../components/Testimonials.astro';
import Pricing from '../components/Pricing.astro';
import Comparison from '../components/Comparison.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="FreeSpeech — Teach Grammar Through Pictures | Language App for Autism & Special Needs"
  description="FreeSpeech is the only app that teaches grammar visually. Children drag and drop picture tiles to build sentences — the app handles the grammar automatically. Based on a TED talk with 1M+ views. Used by SLPs and educators. Free to try."
>
  <Header />
  
  <main>
    <Hero />
    <Problem />
    <Solution />
    <Demo />
    <AhaMoment />
    <Features />
    <Audiences />
    <TEDTalk />
    <Evidence />
    <Testimonials />
    <Pricing />
    <Comparison />
    
    <!-- Final CTA Section -->
    <section id="download" class="final-cta section section-light text-center">
      <div class="container">
        <h2 style="font-size: 2.5rem; margin-bottom: var(--spacing-8);">Start building sentences today.</h2>
        
        <div class="cta-actions">
          <a href="https://apps.apple.com/in/app/avaz-freespeech/id1047763490" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">Download Free on iOS</a>
          <a href="https://play.google.com/store/apps/details?id=com.freespeechapp.en" class="btn btn-secondary" target="_blank" rel="noopener noreferrer">Download Free on Android</a>
        </div>
        <p class="micro-text">Free 14-day trial. No credit card required.</p>
        
        <div class="secondary-cta">
          <p>Are you evaluating FreeSpeech for your school or district?</p>
          <a href="https://samartya.com/for-schools/request-trial" class="text-link" target="_blank" rel="noopener noreferrer">Request a free evaluation with extended access →</a>
        </div>
      </div>
    </section>

    <FAQ />
  </main>

  <Footer />
</Layout>

<style>
  .final-cta {
    padding: var(--spacing-24) 0;
  }
  
  .cta-actions {
    display: flex;
    justify-content: center;
    gap: var(--spacing-4);
    flex-wrap: wrap;
    margin-bottom: var(--spacing-4);
  }

  .micro-text {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-12);
  }

  .secondary-cta {
    background-color: var(--color-bg-alt);
    padding: var(--spacing-6);
    border-radius: var(--border-radius-lg);
    max-width: 600px;
    margin: 0 auto;
  }

  .secondary-cta p {
    margin-bottom: var(--spacing-2);
    font-weight: 500;
  }

  .text-link {
    color: var(--color-primary-dark);
    font-weight: 600;
    text-decoration: none;
  }
  
  .text-link:hover {
    text-decoration: underline;
  }
</style>
