---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Blog"
  description="Articles from the Avaz FreeSpeech team on language learning, AAC, Common Core alignment, and more."
>
  <section class="py-20 px-6 max-w-4xl mx-auto" aria-labelledby="blog-heading">
    <h1
      id="blog-heading"
      class="text-4xl font-extrabold uppercase tracking-wider mb-4"
      style="font-family:'Montserrat',sans-serif; color:#2D2D2D;"
    >
      Blog
    </h1>
    <p class="teal-italic text-lg mb-12">
      Insights on language learning, AAC, and inclusive education
    </p>

    <div class="grid gap-8">
      {posts.map((post) => (
        <article
          class="bg-white rounded-2xl p-8 shadow-md border-t-4 hover:shadow-lg transition-shadow"
          style="border-color:#4ECDC4;"
        >
          <time
            datetime={post.data.date.toISOString()}
            class="text-xs font-semibold uppercase tracking-widest"
            style="color:#4ECDC4; font-family:'Montserrat',sans-serif;"
          >
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <h2
            class="text-xl font-bold uppercase tracking-wide mt-2 mb-3"
            style="font-family:'Montserrat',sans-serif; color:#2D2D2D;"
          >
            <a
              href={`/blog/${post.slug}`}
              class="hover:text-[#4ECDC4] transition-colors focus-visible:text-[#4ECDC4]"
            >
              {post.data.title}
            </a>
          </h2>
          <p class="text-sm leading-relaxed mb-4" style="color:#555;">
            {post.data.description}
          </p>
          <a
            href={`/blog/${post.slug}`}
            class="text-sm font-semibold uppercase tracking-wide hover:underline"
            style="color:#4ECDC4; font-family:'Montserrat',sans-serif;"
            aria-label={`Read more about ${post.data.title}`}
          >
            Read More →
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
