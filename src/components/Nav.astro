---
const navLinks = [
  { label: 'Common Core', href: '/common-core' },
  { label: 'Blog',        href: '/blog' },
  { label: 'FAQ',         href: '/faq' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white shadow-sm">
  <nav
    class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group" aria-label="Avaz FreeSpeech home">
      <span
        class="inline-flex items-center justify-center w-9 h-9 rounded-full text-white font-bold text-sm"
        style="background-color:#4ECDC4; font-family:'Montserrat',sans-serif;"
        aria-hidden="true"
      >FS</span>
      <span
        class="text-lg font-bold tracking-wide uppercase"
        style="font-family:'Montserrat',sans-serif; color:#2D2D2D;"
      >
        Avaz <span style="color:#4ECDC4;">FreeSpeech</span>
      </span>
    </a>

    <!-- Nav links -->
    <ul class="flex items-center gap-8 list-none m-0 p-0" role="list">
      {navLinks.map(({ label, href }) => {
        const isActive = currentPath === href || currentPath.startsWith(href + '/');
        return (
          <li>
            <a
              href={href}
              class="text-sm font-semibold uppercase tracking-wider transition-colors hover:text-[#4ECDC4]"
              style={`font-family:'Montserrat',sans-serif; color:${isActive ? '#4ECDC4' : '#2D2D2D'};`}
              aria-current={isActive ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>
