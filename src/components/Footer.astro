---
// Footer.astro
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col brand-col">
        <h3>FreeSpeech</h3>
        <p>A product of Samartya Apps.</p>
        <div class="social-links">
          <a href="#" aria-label="Facebook">Facebook</a>
          <a href="#" aria-label="Instagram">Instagram</a>
          <a href="#" aria-label="LinkedIn">LinkedIn</a>
          <a href="#" aria-label="YouTube">YouTube</a>
        </div>
      </div>

      <div class="footer-col">
        <h4>Products</h4>
        <ul>
          <li><a href="/">FreeSpeech</a></li>
          <li>
            <a
              href="https://dyslexiareader.com"
              target="_blank"
              rel="noopener noreferrer">Dyslexia Reader</a>
          </li>
          <li>
            <a
              href="https://samartya.com/for-schools"
              target="_blank"
              rel="noopener noreferrer">For Schools</a>
          </li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li>
            <a
              href="https://samartya.com"
              target="_blank"
              rel="noopener noreferrer">About Samartya Apps</a>
          </li>
          <li>
            <a
              href="https://samartya.com/research"
              target="_blank"
              rel="noopener noreferrer">Research & Evidence</a>
          </li>
          <li>
            <a
              href="https://samartya.com/blog"
              target="_blank"
              rel="noopener noreferrer">Blog</a>
          </li>
          <li>
            <a
              href="https://samartya.com/contact"
              target="_blank"
              rel="noopener noreferrer">Contact</a>
          </li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Legal</h4>
        <ul>
          <li>
            <a
              href="https://samartya.com/privacy"
              target="_blank"
              rel="noopener noreferrer">Privacy Policy</a>
          </li>
          <li>
            <a
              href="https://samartya.com/terms"
              target="_blank"
              rel="noopener noreferrer">Terms of Use</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="download-badges">
        <a
          href="https://apps.apple.com/in/app/avaz-freespeech/id1047763490"
          class="badge"
          target="_blank"
          rel="noopener noreferrer">App Store</a
        >
        <a
          href="https://play.google.com/store/apps/details?id=com.freespeechapp.en"
          class="badge"
          target="_blank"
          rel="noopener noreferrer">Google Play</a
        >
      </div>
      <p class="copyright">© {year} Samartya Apps. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-bg-base);
    padding: var(--spacing-16) 0 var(--spacing-8);
    border-top: 1px solid var(--color-border);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--spacing-8);
    margin-bottom: var(--spacing-12);
  }

  .footer-col h3 {
    font-size: 1.5rem;
    margin-bottom: var(--spacing-2);
  }

  .footer-col h4 {
    font-size: 1rem;
    color: var(--color-text-main);
    margin-bottom: var(--spacing-4);
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
  }

  .footer-col ul li {
    margin-bottom: var(--spacing-2);
  }

  .footer-col a {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .footer-col a:hover {
    color: var(--color-primary);
  }

  .brand-col p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: var(--spacing-4);
  }

  .social-links {
    display: flex;
    gap: var(--spacing-4);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--spacing-8);
    border-top: 1px solid var(--color-border);
  }

  .download-badges {
    display: flex;
    gap: var(--spacing-4);
  }

  .badge {
    background-color: var(--color-text-main);
    color: var(--color-bg-surface);
    padding: var(--spacing-2) var(--spacing-4);
    border-radius: var(--border-radius-sm);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .badge:hover {
    background-color: var(--color-primary);
    color: var(--color-bg-surface);
    text-decoration: none;
  }

  .copyright {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 0;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      gap: var(--spacing-6);
      text-align: center;
    }
  }
</style>
