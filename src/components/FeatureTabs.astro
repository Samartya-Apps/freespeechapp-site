---
const features = [
  {
    id: 'picture-tiles',
    label: 'Picture Tiles',
    heading: 'Build Sentences With Picture Tiles',
    body: 'Children select from a library of illustrated tiles representing nouns, verbs, adjectives, and more — dragging them into order to form grammatically correct sentences.',
  },
  {
    id: 'grammar-feedback',
    label: 'Grammar Feedback',
    heading: 'Instant Grammar Feedback',
    body: 'The app highlights structural errors in real time and gently guides children toward the correct sentence structure, reinforcing grammar rules through play.',
  },
  {
    id: 'custom-vocab',
    label: 'Custom Vocabulary',
    heading: 'Personalised Vocabulary Sets',
    body: 'Speech therapists and parents can upload custom images and words, tailoring the experience to topics that matter most to each child.',
  },
  {
    id: 'progress',
    label: 'Progress Tracking',
    heading: 'Track Learning Progress',
    body: 'Detailed reports show mastered sentence structures, vocabulary growth, and session history — giving therapists and educators actionable insights.',
  },
  {
    id: 'common-core',
    label: 'Common Core',
    heading: 'Aligned to Common Core Standards',
    body: 'Activities are mapped to Common Core Language Arts standards, ensuring classroom relevance and making it easy for educators to justify use in school settings.',
  },
];
---

<div
  class="feature-tabs-wrapper"
  x-data="{ active: 'picture-tiles' }"
>
  <!-- Tab list -->
  <div
    role="tablist"
    aria-label="FreeSpeech features"
    class="flex flex-wrap gap-2 mb-8"
  >
    {features.map((f) => (
      <button
        id={`tab-${f.id}`}
        role="tab"
        aria-selected="false"
        aria-controls={`panel-${f.id}`}
        data-tab-id={f.id}
        class="tab-btn px-4 py-2 rounded-full text-sm font-semibold uppercase tracking-wide border-2 transition-all cursor-pointer"
        style="font-family:'Montserrat',sans-serif;"
      >
        {f.label}
      </button>
    ))}
  </div>

  <!-- Tab panels -->
  {features.map((f) => (
    <div
      id={`panel-${f.id}`}
      role="tabpanel"
      aria-labelledby={`tab-${f.id}`}
      data-panel-id={f.id}
      hidden
      class="tab-panel"
    >
      <h3
        class="text-xl font-bold mb-3 uppercase tracking-wide"
        style="font-family:'Montserrat',sans-serif; color:#2D2D2D;"
      >
        {f.heading}
      </h3>
      <p class="text-base leading-relaxed" style="font-family:'Open Sans',sans-serif; color:#2D2D2D;">
        {f.body}
      </p>
    </div>
  ))}
</div>

<script>
  function initTabs() {
    const wrapper = document.querySelector('.feature-tabs-wrapper');
    if (!wrapper) return;

    const buttons = wrapper.querySelectorAll<HTMLButtonElement>('.tab-btn');
    const panels  = wrapper.querySelectorAll<HTMLElement>('.tab-panel');

    function activate(id: string) {
      buttons.forEach((btn) => {
        const isActive = btn.dataset.tabId === id;
        btn.setAttribute('aria-selected', String(isActive));
        btn.style.backgroundColor = isActive ? '#4ECDC4' : 'transparent';
        btn.style.borderColor      = '#4ECDC4';
        btn.style.color            = isActive ? '#fff' : '#4ECDC4';
      });

      panels.forEach((panel) => {
        panel.hidden = panel.dataset.panelId !== id;
      });
    }

    // Set first tab active on load
    activate('picture-tiles');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => activate(btn.dataset.tabId!));

      // Arrow-key keyboard navigation
      btn.addEventListener('keydown', (e: KeyboardEvent) => {
        const list = Array.from(buttons);
        const idx  = list.indexOf(btn);
        if (e.key === 'ArrowRight') {
          list[(idx + 1) % list.length].focus();
        } else if (e.key === 'ArrowLeft') {
          list[(idx - 1 + list.length) % list.length].focus();
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initTabs);
</script>
